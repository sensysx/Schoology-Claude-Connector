# Schoology API credentials
# Get these from: Schoology > Settings > API Access
SCHOOLOGY_CONSUMER_KEY=your_consumer_key_here
SCHOOLOGY_CONSUMER_SECRET=your_consumer_secret_here

# Base URL for your school's Schoology API
# Default is https://api.schoology.com/v1
# If your school has a custom domain (e.g. learn.lcps.org), set this:
SCHOOLOGY_BASE_URL=https://learn.lcps.org/api/v1

# Port to run the server on (default: 3000)
PORT=3000
